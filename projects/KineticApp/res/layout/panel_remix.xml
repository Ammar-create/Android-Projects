<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg2"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_lg">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/space_lg">
            <TextView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Remix" android:textColor="@color/text"
                android:textSize="@dimen/text_lg" android:textStyle="bold" />
            <ImageView android:id="@+id/remixPanelClose"
                android:layout_width="36dp" android:layout_height="36dp"
                android:src="@drawable/ic_close" android:padding="6dp"
                android:background="@drawable/bg_ripple_accent"
                android:contentDescription="Close" />
        </LinearLayout>

        <!-- Source Tabs -->
        <LinearLayout android:id="@+id/remixSourceTabs"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/space_lg">
            <TextView android:id="@+id/remixTabGallery"
                android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1"
                android:text="▦  Gallery" android:gravity="center"
                android:textColor="@color/accent" android:textSize="@dimen/text_sm"
                android:textStyle="bold"
                android:background="@drawable/bg_chip_active"
                android:layout_marginEnd="4dp" />
            <TextView android:id="@+id/remixTabUpload"
                android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1"
                android:text="↑  Upload" android:gravity="center"
                android:textColor="@color/text2" android:textSize="@dimen/text_sm"
                android:background="@drawable/bg_chip" />
        </LinearLayout>

        <!-- Gallery Pick Grid -->
        <GridView android:id="@+id/remixPickGrid"
            android:layout_width="match_parent" android:layout_height="200dp"
            android:numColumns="3" android:horizontalSpacing="6dp"
            android:verticalSpacing="6dp" android:padding="0dp"
            android:layout_marginBottom="@dimen/space_lg" />

        <!-- Upload Zone -->
        <FrameLayout android:id="@+id/remixUploadZone"
            android:layout_width="match_parent" android:layout_height="100dp"
            android:background="@drawable/bg_drop_zone"
            android:layout_marginBottom="@dimen/space_lg"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/pick_image" android:textColor="@color/text3"
                android:textSize="@dimen/text_sm" />
        </FrameLayout>

        <!-- Selected Image Preview -->
        <FrameLayout android:id="@+id/remixSelectedWrap"
            android:layout_width="match_parent" android:layout_height="180dp"
            android:layout_marginBottom="@dimen/space_lg"
            android:visibility="gone">
            <ImageView android:id="@+id/remixSelectedImg"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:scaleType="fitCenter" android:contentDescription="Selected" />
            <ImageView android:id="@+id/remixClearRef"
                android:layout_width="28dp" android:layout_height="28dp"
                android:layout_gravity="top|end"
                android:layout_margin="@dimen/space_xs"
                android:src="@drawable/ic_close" android:padding="4dp"
                android:background="@drawable/bg_scrim"
                android:contentDescription="Clear" />
        </FrameLayout>

        <!-- Action Grid -->
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Quick Actions" android:textColor="@color/text2"
            android:textSize="@dimen/text_sm" android:textStyle="bold"
            android:layout_marginBottom="@dimen/space_xs" />

        <LinearLayout android:id="@+id/actionGrid"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="@dimen/space_lg" />

        <!-- Manual Prompt -->
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Or describe the transformation" android:textColor="@color/text2"
            android:textSize="@dimen/text_sm" android:textStyle="bold"
            android:layout_marginBottom="@dimen/space_xs" />

        <EditText android:id="@+id/remixPromptInput"
            android:layout_width="match_parent"
            android:minHeight="60dp"
            android:layout_height="wrap_content"
            android:hint="@string/remix_prompt_hint"
            android:background="@drawable/bg_input"
            android:padding="@dimen/space_md"
            android:textColor="@color/text" android:textColorHint="@color/text3"
            android:textSize="@dimen/text_sm"
            android:inputType="textMultiLine"
            android:gravity="top|start"
            android:layout_marginBottom="@dimen/space_lg" />

        <!-- Remix Ratio -->
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/ratio_label" android:textColor="@color/text2"
            android:textSize="@dimen/text_sm" android:textStyle="bold"
            android:layout_marginBottom="@dimen/space_xs" />

        <LinearLayout android:id="@+id/remixRatioRow"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/space_lg">
            <TextView android:id="@+id/remixRatioSquare"
                android:layout_width="0dp" android:layout_height="@dimen/chip_height"
                android:layout_weight="1"
                android:text="1:1" android:gravity="center"
                android:textColor="@color/text2" android:textSize="@dimen/text_xs"
                android:background="@drawable/bg_chip"
                android:layout_marginEnd="4dp" />
            <TextView android:id="@+id/remixRatioPortrait"
                android:layout_width="0dp" android:layout_height="@dimen/chip_height"
                android:layout_weight="1"
                android:text="3:4" android:gravity="center"
                android:textColor="@color/text2" android:textSize="@dimen/text_xs"
                android:background="@drawable/bg_chip"
                android:layout_marginEnd="4dp" />
            <TextView android:id="@+id/remixRatioLandscape"
                android:layout_width="0dp" android:layout_height="@dimen/chip_height"
                android:layout_weight="1"
                android:text="16:9" android:gravity="center"
                android:textColor="@color/accent" android:textSize="@dimen/text_xs"
                android:textStyle="bold"
                android:background="@drawable/bg_chip_active" />
        </LinearLayout>

        <!-- Remix Count -->
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/count_label" android:textColor="@color/text2"
            android:textSize="@dimen/text_sm" android:textStyle="bold"
            android:layout_marginBottom="@dimen/space_xs" />

        <LinearLayout android:id="@+id/remixCountRow"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/space_lg">
            <TextView android:id="@+id/remixCount1"
                android:layout_width="44dp" android:layout_height="40dp"
                android:text="1" android:gravity="center"
                android:textColor="@color/accent" android:textSize="@dimen/text_sm"
                android:textStyle="bold"
                android:background="@drawable/bg_chip_active"
                android:layout_marginEnd="8dp" />
            <TextView android:id="@+id/remixCount2"
                android:layout_width="44dp" android:layout_height="40dp"
                android:text="2" android:gravity="center"
                android:textColor="@color/text2" android:textSize="@dimen/text_sm"
                android:background="@drawable/bg_count_btn"
                android:layout_marginEnd="8dp" />
            <TextView android:id="@+id/remixCount3"
                android:layout_width="44dp" android:layout_height="40dp"
                android:text="3" android:gravity="center"
                android:textColor="@color/text2" android:textSize="@dimen/text_sm"
                android:background="@drawable/bg_count_btn"
                android:layout_marginEnd="8dp" />
            <TextView android:id="@+id/remixCount4"
                android:layout_width="44dp" android:layout_height="40dp"
                android:text="4" android:gravity="center"
                android:textColor="@color/text2" android:textSize="@dimen/text_sm"
                android:background="@drawable/bg_count_btn" />
        </LinearLayout>

        <!-- Remix Button -->
        <TextView android:id="@+id/remixBtn"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:gravity="center"
            android:text="@string/remix_btn"
            android:textColor="@color/accent_text"
            android:textSize="@dimen/text_md" android:textStyle="bold"
            android:background="@drawable/bg_btn_generate"
            android:layout_marginTop="@dimen/space_lg" />
    </LinearLayout>
</ScrollView>
